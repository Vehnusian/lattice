    given-names: Hashim
version: 0.1.0
date-released: 2026-05-16
type: software
license: PolyForm-Noncommercial-1.0.0
url: 'https://github.com/Vehnusian/lattice'
repository-code: 'https://github.com/Vehnusian/lattice'
keywords:
  - complex systems
  - agent-based models
  - simulation
  - educational software
  - reproducibility
